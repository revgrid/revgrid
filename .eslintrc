{
  "root": true,
  "ignorePatterns": [
    "projects/**/*"
  ],
  "overrides": [
    {
      "files": [
        "*.ts"
      ],
      "parser": "@typescript-eslint/parser", // Specifies the ESLint parser
      "parserOptions": {
        "ecmaVersion": 2020, // Allows for the parsing of modern ECMAScript features
        "sourceType": "module", // Allows for the use of imports
        "tsconfigRootDir": ".",
        // see notes.md for script to regenerate list of tsconfig files below
        "project": [
          "tsconfig.esm.json",
          "./src/code/adapter-sets/record/tsconfig-rev-record.json",
          "./src/code/adapter-sets/simple/tsconfig-rev-simple.json",
          "./src/code/standard-cell-paint/tsconfig-standard-cell-paint.json",
          "./src/code/grid/tsconfig-grid.json",
          "./src/code/grid/tsconfig-grid-components.json",
          "./src/code/grid/tsconfig-grid-components-renderer.json",
          "./src/code/grid/tsconfig-grid-components-renderer-grid-painter.json",
          "./src/code/grid/tsconfig-grid-components-view.json",
          "./src/code/grid/tsconfig-grid-components-selection.json",
          "./src/code/grid/tsconfig-grid-components-scroller.json",
          "./src/code/grid/tsconfig-behavior.json",
          "./src/code/grid/tsconfig-behavior-components.json",
          "./src/code/grid/tsconfig-behavior-ui.json",
          "./src/code/grid/tsconfig-grid-interfaces.json",
          "./src/code/grid/effects/tsconfig-effects.json",
          "./src/code/grid/lib/tsconfig-lib.json"
        ]
      },
      "extends": [
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended" // Uses the recommended rules from @typescript-eslint/eslint-plugin
        // "plugin:@typescript-eslint/recommended-requiring-type-checking"
        // "plugin:@typescript-eslint/strict"
      ],
      "rules": {
        "no-fallthrough":"error",
        "no-underscore-dangle": "off",
        "prefer-arrow/prefer-arrow-functions": "off",
        "newline-after-description": "off",
        "@typescript-eslint/consistent-type-definitions": "error",
        "@typescript-eslint/quotes": [
          "error",
          "single",
          {
            "avoidEscape": true,
            "allowTemplateLiterals": true
          }
        ],
        "@typescript-eslint/explicit-module-boundary-types": "off",
        "@typescript-eslint/naming-convention": [
          "error",
          {
            "selector": "enumMember",
            "format": null
          }
        ],
        "@typescript-eslint/dot-notation": "off",
        "@typescript-eslint/explicit-member-accessibility": [
          "off",
          {
            "accessibility": "explicit"
          }
        ],
        "no-unused-vars": "off",
        "@typescript-eslint/no-unused-vars": [
          "warn",
          { "args": "none", "varsIgnorePattern": "[iI]gnored", "argsIgnorePattern": "^_" }
        ],
        "@typescript-eslint/no-empty-interface": "off",
        "@typescript-eslint/no-explicit-any": "error",
        "brace-style": [
          "error",
          "1tbs", { "allowSingleLine": true }
        ],
        "@typescript-eslint/no-namespace": "off",
        "@typescript-eslint/prefer-for-of": "off",
        "no-shadow": "off",
        "@typescript-eslint/no-shadow": [
          "error",
          { "ignoreTypeValueShadow": true }
        ],
        "no-return-await": "off",
        "@typescript-eslint/return-await": "error",
        "@typescript-eslint/no-invalid-void-type": [
          "warn",
          { "allowAsThisParameter": true }
        ],
        "no-inner-declarations": "off"
      }
    }
  ]
}
