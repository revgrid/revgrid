{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "npm",
			"script": "lint",
			"problemMatcher": [
				"$eslint-stylish"
			],
			"label": "npm: lint"
		},
		{
			"type": "npm",
			"script": "esm",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [
				"$tsc"
			],
			"label": "build esm"
		},
		{
			"type": "npm",
			"script": "api",
			"group": "build",
			"problemMatcher": [
				"$tsc"
			],
			"label": "build esm"
		},
		{
			"type": "npm",
			"script": "testapp:build",
			"problemMatcher": [
				"$eslint-stylish"
			],
			"label": "npm: test-app:build",
		},
		{
			"type": "npm",
			"script": "testapp:serve",
			"problemMatcher": [
				"$eslint-stylish"
			],
			"label": "npm: test-app:serve",
		}
	]
}
